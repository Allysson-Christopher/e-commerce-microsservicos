# Normalize line endings on commit
* text=auto eol=lf

# Explicit text files
*.md       text eol=lf
*.txt      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.xml      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.java     text eol=lf
*.go       text eol=lf
*.proto    text eol=lf
*.sh       text eol=lf
*.toml     text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf

# Windows-only scripts keep CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary files (never normalize)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      text eol=lf
*.pdf      binary
*.zip      binary
*.tar      binary
*.gz       binary
*.jar      binary
*.war      binary

# Generated / vendor — collapse in PR diffs
package-lock.json    linguist-generated=true
go.sum               linguist-generated=true
*.lock               linguist-generated=true
