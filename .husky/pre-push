#!/usr/bin/env sh
#
# pre-push hook
#
# Blocks direct push to the protected branch (`main`) on this machine.
#
# Why client-side: GitHub Free does not allow server-side branch protection
# nor rulesets on private repositories — both require GitHub Pro / Team /
# Enterprise, or making the repo public. This hook is the documented fallback
# adopted in ADR-0005: a tripwire on the developer machine that enforces
# the trunk-based workflow (branches + PRs) defined in ADR-0003.
#
# This hook is HONEST about its limits:
#   - It runs only on machines where the repo is cloned with husky installed
#     (the prepare script wires it up automatically on `npm install`).
#   - It can be bypassed with `git push --no-verify`, by pushing from another
#     machine, or by calling the GitHub API directly. Treat it as a tripwire,
#     NOT as enforcement. The discipline is yours; this script just removes
#     the "oops" cases.
#   - It does NOT block force-push to other branches. Rebase + push --force on
#     a feature branch is sometimes legitimate (cleaning up before PR).
#
# When this repo gains real server-side protection (going public, upgrading
# to GitHub Pro, or migrating to an org with paid plan), this hook becomes
# redundant but harmless — it can stay as a faster local short-circuit.

set -e

PROTECTED_BRANCH='main'
REMOTE_NAME="$1"   # provided by git: e.g. "origin"
# REMOTE_URL="$2"  # provided by git, unused here

# Read git's stdin: one line per ref being pushed, formatted as
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# We block if any line targets the protected branch.

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    "refs/heads/${PROTECTED_BRANCH}")
      echo "" >&2
      echo "✖ Direct push to '${PROTECTED_BRANCH}' is blocked by .husky/pre-push." >&2
      echo "" >&2
      echo "  Why: this repo follows trunk-based development with PR-only merges" >&2
      echo "       to '${PROTECTED_BRANCH}' (ADR-0003). GitHub Free does not allow" >&2
      echo "       server-side branch protection on private repos, so we enforce" >&2
      echo "       the rule client-side (ADR-0005)." >&2
      echo "" >&2
      echo "  What to do instead:" >&2
      echo "    1. Create a feature branch:  git switch -c feat/<scope>-<slug>" >&2
      echo "    2. Push the branch:          git push -u origin <branch>" >&2
      echo "    3. Open a PR:                gh pr create --fill" >&2
      echo "    4. Squash-merge the PR:      gh pr merge --squash --delete-branch" >&2
      echo "" >&2
      echo "  Bypass (only if you really know what you're doing):" >&2
      echo "    git push --no-verify ${REMOTE_NAME} ${PROTECTED_BRANCH}" >&2
      echo "" >&2
      exit 1
      ;;
  esac
done

exit 0
